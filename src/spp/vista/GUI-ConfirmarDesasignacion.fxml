<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="250.0" prefWidth="450.0" style="-fx-background-color: white; -fx-border-color: #dddddd; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label layoutX="90.0" layoutY="30.0" text="Confirmar Desasignación" textFill="#0a1930">
         <font><Font name="System Bold" size="22.0" /></font>
      </Label>
      <Label alignment="CENTER" layoutX="30.0" layoutY="85.0" prefWidth="390.0" text="¿Estás seguro de que deseas deshacer la Asignación?" textAlignment="CENTER" textFill="#333333" wrapText="true">
         <font><Font size="15.0" /></font>
      </Label>
      <Button layoutX="80.0" layoutY="160.0" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 4; -fx-text-fill: #333333; -fx-cursor: hand;" text="No" />
      <Button layoutX="250.0" layoutY="160.0" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #1b365d; -fx-text-fill: white; -fx-background-radius: 4; -fx-font-weight: bold; -fx-cursor: hand;" text="Sí" />
   </children>
</AnchorPane>