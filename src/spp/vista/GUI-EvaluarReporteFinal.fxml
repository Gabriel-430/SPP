<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="spp.controlador.EvaluarReporteFinalController">
   <children>
      <Label layoutX="30.0" layoutY="20.0" text="Evaluar Reporte Final" textFill="#1b396a">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Separator layoutX="30.0" layoutY="60.0" prefWidth="840.0" />
      <HBox layoutX="30.0" layoutY="80.0" spacing="20.0">
         <children>
            <VBox spacing="10.0">
               <children>
                  <ComboBox fx:id="cmbReportes" onAction="#seleccionarReporte" prefHeight="35.0" prefWidth="550.0" promptText="Seleccione un reporte final a evaluar..." style="-fx-background-color: #f4f7fb; -fx-border-color: #cccccc; -fx-border-radius: 4px;" />
                  <TextArea fx:id="txtVisor" editable="false" prefHeight="420.0" prefWidth="550.0" promptText="Vista previa del reporte..." style="-fx-control-inner-background: #f8fafc; -fx-border-color: #cccccc;" wrapText="true" />
                  <Button fx:id="btnDescargar" onAction="#clicDescargar" prefHeight="35.0" prefWidth="150.0" text="Descargar Archivo" />
               </children>
            </VBox>
            <VBox prefWidth="270.0" spacing="15.0">
               <children>
                  <Label text="Herramientas de Evaluación" textFill="#1b396a">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <Separator prefWidth="200.0" />
                  <Label text="Calificación (0 - 100)" />
                  <TextField fx:id="txtCalificacion" prefHeight="40.0" promptText="Ej. 95" />
                  <Button onAction="#calificar" prefHeight="40.0" prefWidth="270.0" style="-fx-background-color: #1b396a; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar Calificación" />
                  <Button onAction="#clicAgregarObservacion" prefHeight="40.0" prefWidth="270.0" text="Agregar Observación" />
                  <Region VBox.vgrow="ALWAYS" />
                  <Button onAction="#cerrarGUI" prefHeight="40.0" prefWidth="270.0" text="Cancelar y Regresar" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
