<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f4f7fb;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="spp.controlador.LoginController">
   <children>
      <VBox alignment="CENTER" layoutX="250.0" layoutY="115.0" prefHeight="420.0" prefWidth="400.0" spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 35; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.18), 12, 0, 0, 4);">
         <children>
            <Label text="SPP - Inicio de Sesión" textFill="#0a1930">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>

            <Label text="Ingrese sus credenciales para acceder al sistema" textFill="#65748b">
               <font>
                  <Font size="12.0" />
               </font>
            </Label>

            <Separator prefWidth="320.0" />

            <VBox spacing="6.0">
               <children>
                  <Label text="Usuario" textFill="#0a1930" />
                  <TextField fx:id="tfNombreUsuario" prefHeight="38.0" prefWidth="320.0" promptText="Ingrese su nombre de usuario" style="-fx-background-color: white; -fx-border-color: #d9e1ec; -fx-border-radius: 4; -fx-background-radius: 4;" />
               </children>
            </VBox>

            <VBox spacing="6.0">
               <children>
                  <Label text="Contraseña" textFill="#0a1930" />
                  <PasswordField fx:id="pfContrasenia" prefHeight="38.0" prefWidth="320.0" promptText="Ingrese su contraseña" style="-fx-background-color: white; -fx-border-color: #d9e1ec; -fx-border-radius: 4; -fx-background-radius: 4;" />
               </children>
            </VBox>

            <Label fx:id="lblMensajeError" textFill="#b00020" wrapText="true">
               <font>
                  <Font size="12.0" />
               </font>
            </Label>

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="btnSalir" mnemonicParsing="false" onAction="#salir" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-font-size: 14px; -fx-background-radius: 4; -fx-cursor: hand;" text="Salir" />

                  <Button fx:id="btnIniciarSesion" defaultButton="true" mnemonicParsing="false" onAction="#iniciarSesion" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #1b365d; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 4; -fx-cursor: hand;" text="Iniciar Sesión" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
